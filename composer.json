{
    "name": "fanatique/php-fixed-length-file-parser",
    "description": "A parser class for handling fixed length text files in PHP",
    "keywords": ["php", "text", "parser", "fixed-length"],
    "homepage": "https://github.com/fanatique/php-fixed-length-file-parser",
    "license": "MIT",
    "authors": [
        {
            "name": "Alexander Thomas",
            "email": "me@alexander-thomas.net",
            "homepage": "https://alexander-thomas.net"
        }
    ],
    "autoload": {
        "psr-4": {
            "Fanatique\\Parser\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fanatique\\Parser\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse"
    }
}
